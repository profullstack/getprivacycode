#!/usr/bin/env bash
set -e

# Resolve real path (follow symlinks from npm link)
if command -v greadlink &>/dev/null; then
  REAL="$(greadlink -f "$0")"
else
  REAL="$(readlink -f "$0" 2>/dev/null || realpath "$0" 2>/dev/null || python3 -c "import os; print(os.path.realpath('$0'))")"
fi
SCRIPT_DIR="$(dirname "$REAL")"
PKG_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

# Try native binary first
BIN="$PKG_DIR/.privacycode"
if [ -f "$BIN" ]; then
  exec "$BIN" "$@"
fi

# Fall back to bun dev
ROOT="$(cd "$PKG_DIR/../.." && pwd)"
exec bun run --cwd "$PKG_DIR" --conditions=browser src/index.ts "$@"
